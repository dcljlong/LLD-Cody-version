import React, { useEffect, useState } from 'react';
import { Link } from 'react-router-dom';
import { jobsApi } from '../lib/api';
import { toast } from 'sonner';
import {
  FolderOpen,
  MapPin,
  Building2,
  Calendar,
  Hash,
  ArrowRight
} from 'lucide-react';
import { Button } from '../components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';

const ProjectsPage = () => {
  const [jobs, setJobs] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchJobs();
  }, []);

  const fetchJobs = async () => {
    try {
      setLoading(true);
      const res = await jobsApi.getAll();
      setJobs(Array.isArray(res?.data?.value) ? res.data.value : []);
    } catch (error) {
      console.error(error);
      toast.error('Failed to load jobs');
      setJobs([]);
    } finally {
      setLoading(false);
    }
  };

  const formatDate = (value) => {
    if (!value) return '—';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '—';
    return date.toLocaleDateString('en-NZ', {
      day: '2-digit',
      month: 'short',
      year: 'numeric'
    });
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center py-20">
        <div className="w-8 h-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
      </div>
    );
  }

  return (
    <div className="space-y-6" data-testid="projects-page">
      <div className="flex items-center justify-between">
        <div>
          <h2 className="font-heading text-2xl font-bold tracking-tight uppercase">Jobs</h2>
          <p className="text-sm text-muted-foreground">
            {jobs.length} job{jobs.length !== 1 ? 's' : ''}
          </p>
        </div>
      </div>

      {jobs.length > 0 ? (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {jobs.map((job) => (
            <Card key={job.id} className="ops-card group" data-testid={`job-${job.id}`}>
              <CardHeader className="ops-card-header py-3">
                <CardTitle className="font-heading text-lg tracking-tight truncate">
                  {job.job_name || 'Untitled Job'}
                </CardTitle>
              </CardHeader>

              <CardContent className="py-4">
                <div className="space-y-2 text-sm">
                  <div className="flex items-center gap-2 text-muted-foreground">
                    <Hash className="w-4 h-4" />
                    <span>{job.job_number || '—'}</span>
                  </div>

                  {job.main_contractor && (
                    <div className="flex items-center gap-2 text-muted-foreground">
                      <Building2 className="w-4 h-4" />
                      <span>{job.main_contractor}</span>
                    </div>
                  )}

                  {job.site_address && (
                    <div className="flex items-center gap-2 text-muted-foreground">
                      <MapPin className="w-4 h-4" />
                      <span>{job.site_address}</span>
                    </div>
                  )}

                  <div className="flex items-center gap-2 text-muted-foreground">
                    <Calendar className="w-4 h-4" />
                    <span>Planned start {formatDate(job.planned_start)}</span>
                  </div>

                  <div className="flex items-center gap-2 text-muted-foreground">
                    <Calendar className="w-4 h-4" />
                    <span>Created {formatDate(job.created_at)}</span>
                  </div>
                </div>

                {job.latest_analysis?.job_summary && (
                  <p className="text-sm text-muted-foreground mt-3 line-clamp-3">
                    {job.latest_analysis.job_summary}
                  </p>
                )}

                <div className="mt-4 pt-4 border-t border-border flex items-center justify-between">
                  <span className={`status-badge ${job.status === 'active' ? 'status-on-track' : 'status-completed'}`}>
                    {job.status || 'unknown'}
                  </span>

                  <Link to={`/projects/${job.id}`}>
                    <Button variant="ghost" size="sm" className="text-primary">
                      View <ArrowRight className="w-4 h-4 ml-1" />
                    </Button>
                  </Link>
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      ) : (
        <div className="empty-state py-20">
          <FolderOpen className="empty-state-icon" />
          <p className="empty-state-title">No Jobs Found</p>
          <p className="empty-state-description mb-4">
            No jobs are available from the backend yet.
          </p>
        </div>
      )}
    </div>
  );
};

export default ProjectsPage;
